# Example environment file for Africa Risk Map.
#
# Copy to `.env` and fill in real values locally. NEVER commit `.env` or any
# real secret/credential ? `.env` is gitignored; only this `.env.example`
# (placeholders only) is tracked. See docs/environment-setup.md,
# .cursor/rules/10-security-popia.mdc, and .cursor/rules/90-project-context.mdc.
#
# During typecheck/lint/test/build these only need to be present and
# well-formed, not live ? no database or third-party service is contacted.

# --- Database (PostgreSQL + PostGIS; Neon in cloud, Docker Compose locally) ---
# Pooled connection string ? used by the app runtime (serverless-safe).
DATABASE_URL="postgresql://user:password@host-pooler.neon.tech/africa_risk_map?sslmode=require"
# Direct/unpooled connection string ? used only for migrations.
DIRECT_URL="postgresql://user:password@host.neon.tech/africa_risk_map?sslmode=require"

# For local Docker Compose (see docker-compose.yml) both point at localhost:
# DATABASE_URL="postgresql://africa_risk_map:africa_risk_map@localhost:5432/africa_risk_map?schema=public"
# DIRECT_URL="postgresql://africa_risk_map:africa_risk_map@localhost:5432/africa_risk_map?schema=public"

# --- Auth (Clerk) ---
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY="pk_test_xxxxxxxx"
CLERK_SECRET_KEY="sk_test_xxxxxxxx"
NEXT_PUBLIC_CLERK_SIGN_IN_URL="/sign-in"
NEXT_PUBLIC_CLERK_SIGN_UP_URL="/sign-up"

# --- Error tracking (Sentry) ? optional; no-op when unset ---
NEXT_PUBLIC_SENTRY_DSN=""
SENTRY_AUTH_TOKEN=""
SENTRY_ORG=""
SENTRY_PROJECT=""

# --- Background jobs (Inngest) ? idle when unset ---
INNGEST_EVENT_KEY=""
INNGEST_SIGNING_KEY=""

# --- AI provider (Anthropic) ? wired in the policy-structure-chat / ai-news-monitor to-dos ---
ANTHROPIC_API_KEY=""

# --- Basemap tiles (Cloudflare R2) ? wired in the import-scripts-data to-do ---
R2_ACCOUNT_ID=""
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""
R2_BUCKET_NAME=""
R2_PUBLIC_BASE_URL=""

# --- E2E (Playwright) ? Clerk test user for critical-flow e2e; leave blank to skip e2e ---
E2E_CLERK_USER_EMAIL=""
