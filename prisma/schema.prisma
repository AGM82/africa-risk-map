// Prisma schema — Africa Risk Map Platform
//
// Domain models are added incrementally by their own to-dos. This file currently
// establishes:
//   - PostgreSQL + PostGIS datasource, pooled (runtime) vs direct (migrations) URLs
//   - The AuditLogEntry model, which every later to-do's mutations write to
//   - Client / BrokerOrganisation / ClientBrokerAssignment (multi-tenant backbone)
//   - Shared/global Territory + TerritoryRiskHistory (risk register)
//   - Shared/global spatial reference layers (AdminBoundary, Airport,
//     HealthFacility, Place) + SpatialDatasetRefresh provenance
//   - The Row-Level Security pattern (see prisma/migrations/0001_init/migration.sql
//     and 0004_client_broker) that every later clientId-scoped table must replicate
//
// Geometry columns use Unsupported("geometry(...)") — see
// docs/prisma-postgis-geometry.md and src/lib/db/spatial.ts.
generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  directUrl  = env("DIRECT_URL")
  extensions = [postgis]
}

/// Platform role, mirrored from Clerk user metadata into the session-token claim
/// that both Prisma query scoping and Postgres RLS policies key on.
enum UserRole {
  INSURER_ADMIN
  BROKER
  CLIENT
}

enum AuditAction {
  CREATE
  UPDATE
  DELETE
  ANONYMIZE
  CONFIRM
  LOGIN
  ACCESS_CHANGE
}

/// Conventional risk-severity tiers (map colour exception — see Design & UX).
enum RiskCategory {
  Low
  Medium
  High
  VeryHigh  @map("Very High")
  Extreme

  @@map("RiskCategory")
}

/// Territory Benefit Options Available from the Risk Rating Table.
enum BenefitOptionsAvailable {
  CATEGORIES_1_2
  CATEGORIES_3_4
  CATEGORY_4_ONLY
  DECLINE
}

/// Lifecycle status of an insured Client organisation.
enum ClientStatus {
  ACTIVE
  INACTIVE
}

/// Immutable, append-only audit trail for every state-changing action across the
/// platform (territory edits, endorsements, policy confirmations, user-admin
/// access changes, AI-drafted-record confirmations, etc.). Never updated or
/// deleted by application code.
///
/// `clientId` is null for actions against shared/global entities (e.g. Territory,
/// user administration); non-null for client-scoped entities. This is the field
/// the RLS policy below filters on.
model AuditLogEntry {
  id           String      @id @default(cuid())
  actorUserId  String
  actorRole    UserRole
  clientId     String?
  entityType   String
  entityId     String
  action       AuditAction
  diff         Json?
  createdAt    DateTime    @default(now())

  @@index([clientId])
  @@index([entityType, entityId])
  @@index([createdAt])
  @@map("audit_log_entries")
}

// ---------------------------------------------------------------------------
// Multi-tenant backbone: Client, BrokerOrganisation, ClientBrokerAssignment.
// Client is the tenant root — AuthContext.clientId is a Client.id. RLS is
// keyed on app.current_client_id / app.current_broker_org_id (see the pattern
// in prisma/migrations/0001_init/migration.sql and 0004_client_broker).
// ---------------------------------------------------------------------------

/// An insured association/organisation (e.g. GRAA). Tenant root: every
/// client-scoped table's clientId points here. Never holds insured-person or
/// financial data directly — those hang off its Policies/Organisations.
model Client {
  id          String                   @id @default(cuid())
  /// Human-readable name (anonymised placeholder only in seed/fixtures).
  name        String
  /// Stable URL-safe slug used in routes and logs (e.g. "graa").
  code        String                   @unique
  status      ClientStatus             @default(ACTIVE)
  createdAt   DateTime                 @default(now())
  updatedAt   DateTime                 @updatedAt
  assignments             ClientBrokerAssignment[]
  memberOrganisations     MemberOrganisation[]
  recalibrationBatches    RecalibrationBatch[]
  paymentTerms            PaymentTerms[]
  policies                Policy[]
  riskMixPolicies         RiskMixPolicy[]
  structureSessions       PolicyStructureSession[]
  endorsements            Endorsement[]

  @@index([status])
  @@map("clients")
}

/// A brokerage servicing one or more Clients (e.g. Lombard's own brokerage or
/// a third-party broker). Shared admin entity — no clientId, Insurer-managed.
/// BROKER users belong to a BrokerOrganisation via Clerk metadata.
model BrokerOrganisation {
  id          String                   @id @default(cuid())
  name        String
  code        String                   @unique
  createdAt   DateTime                 @default(now())
  updatedAt   DateTime                 @updatedAt
  assignments ClientBrokerAssignment[]

  @@map("broker_organisations")
}

/// Effective-dated link between a Client and the BrokerOrganisation servicing
/// it. A broker change at renewal closes the old row (effectiveTo set) and
/// opens a new one, so history is never lost. effectiveTo IS NULL = current.
model ClientBrokerAssignment {
  id                   String             @id @default(cuid())
  clientId             String
  client               Client             @relation(fields: [clientId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  brokerOrganisationId String
  brokerOrganisation   BrokerOrganisation @relation(fields: [brokerOrganisationId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  effectiveFrom        DateTime           @default(now())
  effectiveTo          DateTime?
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt

  @@index([clientId])
  @@index([brokerOrganisationId])
  @@index([effectiveTo])
  @@map("client_broker_assignments")
}

// ---------------------------------------------------------------------------
// Shared / global Territory risk register (no clientId, no RLS).
// ---------------------------------------------------------------------------

/// Country or rated sub-region (e.g. "Nigeria" + "North-East"). Shared source of
/// truth maintained by the Insurer. Empty string for subRegion = whole-country.
model Territory {
  id                       String                  @id @default(cuid())
  country                  String
  /// Empty string when the row rates the whole country (not a sub-region).
  subRegion                String                  @default("")
  graaPresence             Boolean                 @default(false)
  countryHeadcount         Int?
  healthcareInfrastructure Int
  medicalPersonnel         Int
  medicalTransport         Int
  emergencyResponse        Int
  securityConflict         Int
  occupationalHazards      Int
  totalScore               Int
  riskCategory             RiskCategory
  evacuationPaths          String?
  evacCostEstimate         Decimal?                @db.Decimal(12, 2)
  benefitOptions           BenefitOptionsAvailable
  contextNotes             String?
  evacuationFeasible       Boolean                 @default(true)
  /// Optional join key to geoBoundaries ADM1 externalId when mapped.
  adminBoundaryExternalId  String?
  isoCountry               String?
  createdAt                DateTime                @default(now())
  updatedAt                DateTime                @updatedAt
  history                  TerritoryRiskHistory[]
  organisationLocations    OrganisationLocation[]
  territoryBenefitEligibilities TerritoryBenefitEligibility[]

  @@unique([country, subRegion])
  @@index([riskCategory])
  @@index([graaPresence])
  @@index([isoCountry])
  @@map("territories")
}

/// Immutable snapshot of risk scores after each Insurer edit.
/// Parent delete is RESTRICT so history cannot be destroyed under audit.
model TerritoryRiskHistory {
  id                       String       @id @default(cuid())
  territoryId              String
  territory                Territory    @relation(fields: [territoryId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  healthcareInfrastructure Int
  medicalPersonnel         Int
  medicalTransport         Int
  emergencyResponse        Int
  securityConflict         Int
  occupationalHazards      Int
  totalScore               Int
  riskCategory             RiskCategory
  actorUserId              String
  createdAt                DateTime     @default(now())

  @@index([territoryId])
  @@index([createdAt])
  @@map("territory_risk_history")
}

// ---------------------------------------------------------------------------
// Shared / global spatial reference layers (no clientId, no RLS).
// Geometry columns are Unsupported — spatial I/O via $queryRaw/$executeRaw
// only. See docs/prisma-postgis-geometry.md and src/lib/db/spatial.ts.
// ---------------------------------------------------------------------------

/// Provenance row for one import of a spatial dataset (source + last refresh).
model SpatialDatasetRefresh {
  id              String   @id @default(cuid())
  /// Stable source key: geoboundaries | ourairports | healthsites | geonames
  source          String   @unique
  lastRefreshedAt DateTime
  checksum        String?
  rowCount        Int?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  adminBoundaries  AdminBoundary[]
  airports         Airport[]
  healthFacilities HealthFacility[]
  places           Place[]

  @@map("spatial_dataset_refreshes")
}

/// Sub-national admin polygon (geoBoundaries ADM1). isoCountry = ISO alpha-3.
model AdminBoundary {
  id              String                    @id @default(cuid())
  externalId      String
  name            String
  isoCountry      String
  shapeType       String                    @default("ADM1")
  source          String
  sourceUpdatedAt DateTime?
  refreshId       String?
  refresh         SpatialDatasetRefresh?    @relation(fields: [refreshId], references: [id], onDelete: SetNull, onUpdate: Cascade)
  /// Opaque to Prisma — read/write via ST_GeomFromText / ST_AsGeoJSON raw SQL.
  geom            Unsupported("geometry(MultiPolygon,4326)")
  createdAt       DateTime                  @default(now())
  updatedAt       DateTime                  @updatedAt

  @@unique([source, externalId])
  @@index([isoCountry])
  @@index([source])
  @@index([refreshId])
  @@map("admin_boundaries")
}

/// Airport / airstrip point (OurAirports). isoCountry = ISO alpha-2.
model Airport {
  id              String                 @id @default(cuid())
  externalId      String
  name            String
  isoCountry      String
  iataCode        String?
  icaoCode        String?
  type            String?
  source          String
  sourceUpdatedAt DateTime?
  refreshId       String?
  refresh         SpatialDatasetRefresh? @relation(fields: [refreshId], references: [id], onDelete: SetNull, onUpdate: Cascade)
  geom            Unsupported("geometry(Point,4326)")
  createdAt       DateTime               @default(now())
  updatedAt       DateTime               @updatedAt

  @@unique([source, externalId])
  @@index([isoCountry])
  @@index([source])
  @@index([refreshId])
  @@map("airports")
}

/// Hospital / clinic point (healthsites.io). isoCountry = ISO alpha-3 when known.
model HealthFacility {
  id              String                 @id @default(cuid())
  externalId      String
  name            String
  isoCountry      String?
  amenity         String?
  source          String
  sourceUpdatedAt DateTime?
  refreshId       String?
  refresh         SpatialDatasetRefresh? @relation(fields: [refreshId], references: [id], onDelete: SetNull, onUpdate: Cascade)
  geom            Unsupported("geometry(Point,4326)")
  createdAt       DateTime               @default(now())
  updatedAt       DateTime               @updatedAt

  @@unique([source, externalId])
  @@index([isoCountry])
  @@index([source])
  @@index([refreshId])
  @@map("health_facilities")
}

/// Populated place point (GeoNames). isoCountry = ISO alpha-2.
model Place {
  id              String                 @id @default(cuid())
  externalId      String
  name            String
  isoCountry      String
  featureClass    String?
  featureCode     String?
  population      Int?
  source          String
  sourceUpdatedAt DateTime?
  refreshId       String?
  refresh         SpatialDatasetRefresh? @relation(fields: [refreshId], references: [id], onDelete: SetNull, onUpdate: Cascade)
  geom            Unsupported("geometry(Point,4326)")
  createdAt       DateTime               @default(now())
  updatedAt       DateTime               @updatedAt

  @@unique([source, externalId])
  @@index([isoCountry])
  @@index([source])
  @@index([refreshId])
  @@map("places")
}

// ---------------------------------------------------------------------------
// Client-scoped member organisations and their territory locations.
// RLS keyed on clientId (same broker-visible-clients pattern as 0004).
// CoverCategory FK lands in policy-structure; assignedPlanType is interim.
// ---------------------------------------------------------------------------

/// Lifecycle of a member organisation within a Client's book.
enum MemberOrganisationStatus {
  PENDING_SUBMISSION
  UNDER_REVIEW
  ACTIVE
  DECLINED
}

/// Interim plan/category label until CoverCategory records exist per Policy.
enum PlanType {
  ESSENTIAL
  PREMIUM
}

/// A reserve/park operator (or similar) belonging to a Client (e.g. GRAA).
model MemberOrganisation {
  id                       String                   @id @default(cuid())
  clientId                 String
  client                   Client                   @relation(fields: [clientId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  name                     String
  status                   MemberOrganisationStatus @default(PENDING_SUBMISSION)
  defaultPlanType          PlanType                 @default(ESSENTIAL)
  riskMgmtPlanOnFile       Boolean                  @default(false)
  crisisMgmtPlanOnFile     Boolean                  @default(false)
  fullUnderwritingApproved Boolean                  @default(false)
  createdAt                DateTime                 @default(now())
  updatedAt                DateTime                 @updatedAt
  locations                OrganisationLocation[]

  @@index([clientId])
  @@index([status])
  @@map("member_organisations")
}

/// A member org's presence in a Territory with headcount and cover assignment.
/// Endorsements attach here; parent delete is RESTRICT once endorsements exist.
model OrganisationLocation {
  id                    String             @id @default(cuid())
  clientId              String
  memberOrganisationId  String
  memberOrganisation    MemberOrganisation @relation(fields: [memberOrganisationId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  territoryId           String
  territory             Territory          @relation(fields: [territoryId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  /// Site label within the territory (e.g. park/reserve name).
  siteName              String
  headcount             Int                @default(0)
  /// Kept in sync with CoverCategory.planType when coverCategoryId is set.
  assignedPlanType      PlanType
  coverCategoryId       String?
  coverCategory         CoverCategory?     @relation(fields: [coverCategoryId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  createdAt             DateTime           @default(now())
  updatedAt             DateTime           @updatedAt
  endorsements          Endorsement[]

  @@index([clientId])
  @@index([memberOrganisationId])
  @@index([territoryId])
  @@index([coverCategoryId])
  @@map("organisation_locations")
}

enum EndorsementKind {
  BASELINE
  ADD
  REMOVE
}

/// Headcount ledger row against an OrganisationLocation (replaces Excel endorsement rows).
/// Parent location delete is RESTRICT so financial history cannot be destroyed.
model Endorsement {
  id                     String               @id @default(cuid())
  clientId               String
  client                 Client               @relation(fields: [clientId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  organisationLocationId String
  organisationLocation   OrganisationLocation @relation(fields: [organisationLocationId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  coverCategoryId        String
  coverCategory          CoverCategory        @relation(fields: [coverCategoryId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  policyId               String
  policy                 Policy               @relation(fields: [policyId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  /// Positive for BASELINE/ADD; negative for REMOVE. Never zero.
  delta                  Int
  effectiveDate          DateTime
  note                   String?
  kind                   EndorsementKind
  createdByUserId        String
  createdAt              DateTime             @default(now())

  @@index([clientId])
  @@index([organisationLocationId])
  @@index([coverCategoryId])
  @@index([policyId])
  @@index([effectiveDate])
  @@map("endorsements")
}

// ---------------------------------------------------------------------------
// Client-scoped recalibration: reconcile org/location headcounts against
// ledger PlanType baselines until balanced, then lock. Endorsements bootstrap on lock.
// ---------------------------------------------------------------------------

enum RecalibrationStatus {
  IN_PROGRESS
  LOCKED
}

/// One-time reconciliation batch per client against PlanType headcount baselines.
model RecalibrationBatch {
  id             String              @id @default(cuid())
  clientId       String
  client         Client              @relation(fields: [clientId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  status         RecalibrationStatus @default(IN_PROGRESS)
  /// PlanType baselines: { "ESSENTIAL": number, "PREMIUM": number }
  baselines      Json
  lockedAt       DateTime?
  lockedByUserId String?
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt

  @@index([clientId])
  @@index([status])
  @@map("recalibration_batches")
}

// ---------------------------------------------------------------------------
// Client-scoped Policy Schedule (annual term) + RiskMixPolicy.
// benefitScale: FIXED_SUM (GPA) vs EARNINGS_BASED (Stated Benefits).
// ---------------------------------------------------------------------------

enum PolicyStatus {
  QUOTED
  BOUND
  ON_RISK
  EXPIRED
  RENEWED
}

/// GPA Fixed Sum vs Stated Benefits (earnings-based compensation).
enum BenefitScale {
  FIXED_SUM
  EARNINGS_BASED
}

enum RateBasis {
  PER_PERSON_PER_MONTH
  PER_ANNUM
  PERCENT_OF_WAGE_ROLL
}

enum BenefitType {
  DEATH
  PTD
  TTD
  MEDICAL
  EVACUATION
}

enum BenefitAmountBasis {
  LUMP_SUM
  PERIODIC
}

enum PaymentFrequency {
  MONTHLY_BY_NUMBERS
  ANNUAL_WITH_ADJUSTMENT
  ANNUAL_FLAT
}

/// How a Policy bills (frequency + aggregate fund treatment).
model PaymentTerms {
  id                      String           @id @default(cuid())
  clientId                String
  client                  Client           @relation(fields: [clientId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  frequency               PaymentFrequency
  depositMinPremium       Decimal?         @db.Decimal(14, 2)
  adjustmentCadenceMonths Int?
  aggregateIsClientFund   Boolean          @default(true)
  createdAt               DateTime         @default(now())
  updatedAt               DateTime         @updatedAt
  policies                Policy[]

  @@index([clientId])
  @@map("payment_terms")
}

/// One annual Policy Schedule per client per policyYear.
model Policy {
  id                   String         @id @default(cuid())
  clientId             String
  client               Client         @relation(fields: [clientId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  policyYear           String
  inceptionDate        DateTime
  expiryDate           DateTime
  status               PolicyStatus   @default(QUOTED)
  benefitScale         BenefitScale   @default(FIXED_SUM)
  paymentTermsId       String
  paymentTerms         PaymentTerms   @relation(fields: [paymentTermsId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  underwriterUserId    String?
  brokerOrganisationId String?
  createdAt            DateTime       @default(now())
  updatedAt            DateTime       @updatedAt
  coverCategories      CoverCategory[]
  structureSessions    PolicyStructureSession[]
  endorsements         Endorsement[]

  @@unique([clientId, policyYear])
  @@index([clientId])
  @@index([status])
  @@index([paymentTermsId])
  @@map("policies")
}

/// Insured-person category within a Policy (rates + plan type + benefits).
model CoverCategory {
  id                     String           @id @default(cuid())
  policyId               String
  policy                 Policy           @relation(fields: [policyId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  clientId               String
  categoryLabel          String
  planType               PlanType
  declaredInsuredCount   Int              @default(0)
  /// Anonymised aggregate wage roll for EARNINGS_BASED rating (optional).
  declaredAnnualWageRoll Decimal?         @db.Decimal(16, 2)
  premiumAmount          Decimal          @db.Decimal(14, 4)
  premiumBasis           RateBasis
  premiumIncludesVat     Boolean          @default(true)
  aggregateAmount        Decimal          @db.Decimal(14, 4)
  aggregateBasis         RateBasis
  aggregateExcludesVat   Boolean          @default(true)
  sortOrder              Int              @default(0)
  createdAt              DateTime         @default(now())
  updatedAt              DateTime         @updatedAt
  benefitLines           BenefitLine[]
  territoryEligibilities TerritoryBenefitEligibility[]
  organisationLocations  OrganisationLocation[]
  endorsements           Endorsement[]

  @@index([policyId])
  @@index([clientId])
  @@index([planType])
  @@map("cover_categories")
}

/// Benefit schedule line (Death/PTD/TTD/Medical/Evac) — Fixed Sum or Earnings fields.
model BenefitLine {
  id                 String             @id @default(cuid())
  coverCategoryId    String
  coverCategory      CoverCategory      @relation(fields: [coverCategoryId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  clientId           String
  benefitType        BenefitType
  amountBasis        BenefitAmountBasis
  waitingPeriodDays  Int?
  maxBenefitWeeks    Int?
  notes              String?
  /// FIXED_SUM amount (Death/PTD sum; TTD weekly; Medical/Evac limit).
  fixedAmount        Decimal?           @db.Decimal(14, 2)
  /// EARNINGS_BASED: multiple of annual earnings (Death/PTD).
  earningsMultiple   Decimal?           @db.Decimal(8, 4)
  /// EARNINGS_BASED: percent of weekly earnings (TTD), e.g. 100.
  percentOfEarnings  Decimal?           @db.Decimal(8, 4)
  /// Optional rand cap on an earnings-derived benefit.
  maxAmountCap       Decimal?           @db.Decimal(14, 2)
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt

  @@unique([coverCategoryId, benefitType])
  @@index([clientId])
  @@map("benefit_lines")
}

/// Which CoverCategories a Territory may use (policy-year aware via CoverCategory).
model TerritoryBenefitEligibility {
  id              String        @id @default(cuid())
  territoryId     String
  territory       Territory     @relation(fields: [territoryId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  coverCategoryId String
  coverCategory   CoverCategory @relation(fields: [coverCategoryId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  clientId        String
  createdAt       DateTime      @default(now())

  @@unique([territoryId, coverCategoryId])
  @@index([clientId])
  @@index([territoryId])
  @@index([coverCategoryId])
  @@map("territory_benefit_eligibilities")
}

/// Per-client target mix of covered lives across risk tiers (rate-guarantee guard).
model RiskMixPolicy {
  id                 String    @id @default(cuid())
  clientId           String
  client             Client    @relation(fields: [clientId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  targetLowMedPct    Decimal   @db.Decimal(5, 2)
  targetHighPct      Decimal   @db.Decimal(5, 2)
  targetVeryHighPct  Decimal   @db.Decimal(5, 2)
  tolerancePct       Decimal   @db.Decimal(5, 2)
  effectiveFrom      DateTime  @default(now())
  effectiveTo        DateTime?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  @@index([clientId])
  @@index([effectiveTo])
  @@map("risk_mix_policies")
}

// ---------------------------------------------------------------------------
// AI Structure Chat — PolicyTemplate + PolicyStructureSession (advisory until confirm).
// ---------------------------------------------------------------------------

enum StructureSessionStatus {
  DRAFTING
  REVIEWING
  CONFIRMED
  CANCELLED
}

enum StructureConfirmTarget {
  POLICY
  TEMPLATE
  BOTH
}

/// Reusable, not-yet-client-bound schedule shape (categories + benefits + payment terms).
model PolicyTemplate {
  id              String         @id @default(cuid())
  name            String
  description     String?
  benefitScale    BenefitScale   @default(FIXED_SUM)
  /// JSON: payment terms + categories + benefit lines (draft payload shape).
  structureJson   Json
  createdByUserId String
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  sessions        PolicyStructureSession[]

  @@index([benefitScale])
  @@map("policy_templates")
}

/// Audit trail for AI-assisted policy structuring — nothing is real until CONFIRMED.
model PolicyStructureSession {
  id                   String                   @id @default(cuid())
  clientId             String?
  client               Client?                  @relation(fields: [clientId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  policyYear           String?
  status               StructureSessionStatus   @default(DRAFTING)
  benefitScale         BenefitScale             @default(FIXED_SUM)
  sourceText           String
  /// Append-only version history: [{ at, actorUserId, kind, draft }].
  versionsJson         Json
  currentDraftJson     Json
  uncertainFieldsJson  Json
  confirmTarget        StructureConfirmTarget?
  confirmedPolicyId    String?
  confirmedPolicy      Policy?                  @relation(fields: [confirmedPolicyId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  confirmedTemplateId  String?
  confirmedTemplate    PolicyTemplate?          @relation(fields: [confirmedTemplateId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  confirmedByUserId    String?
  confirmedAt          DateTime?
  createdByUserId      String
  createdAt            DateTime                 @default(now())
  updatedAt            DateTime                 @updatedAt

  @@index([clientId])
  @@index([status])
  @@index([confirmedPolicyId])
  @@index([confirmedTemplateId])
  @@map("policy_structure_sessions")
}
