// Prisma schema — Africa Risk Map Platform
//
// Domain models are added incrementally by their own to-dos. This file currently
// establishes:
//   - PostgreSQL + PostGIS datasource, pooled (runtime) vs direct (migrations) URLs
//   - The AuditLogEntry model, which every later to-do's mutations write to
//   - Client / BrokerOrganisation / ClientBrokerAssignment (multi-tenant backbone)
//   - Shared/global Territory + TerritoryRiskHistory (risk register)
//   - Shared/global spatial reference layers (AdminBoundary, Airport,
//     HealthFacility, Place) + SpatialDatasetRefresh provenance
//   - The Row-Level Security pattern (see prisma/migrations/0001_init/migration.sql
//     and 0004_client_broker) that every later clientId-scoped table must replicate
//
// Geometry columns use Unsupported("geometry(...)") — see
// docs/prisma-postgis-geometry.md and src/lib/db/spatial.ts.
generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  directUrl  = env("DIRECT_URL")
  extensions = [postgis]
}

/// Platform role, mirrored from Clerk user metadata into the session-token claim
/// that both Prisma query scoping and Postgres RLS policies key on.
enum UserRole {
  INSURER_ADMIN
  BROKER
  CLIENT
}

enum AuditAction {
  CREATE
  UPDATE
  DELETE
  ANONYMIZE
  CONFIRM
  LOGIN
  ACCESS_CHANGE
}

/// Conventional risk-severity tiers (map colour exception — see Design & UX).
enum RiskCategory {
  Low
  Medium
  High
  VeryHigh  @map("Very High")
  Extreme

  @@map("RiskCategory")
}

/// Territory Benefit Options Available from the Risk Rating Table.
enum BenefitOptionsAvailable {
  CATEGORIES_1_2
  CATEGORIES_3_4
  CATEGORY_4_ONLY
  DECLINE
}

/// Lifecycle status of an insured Client organisation.
enum ClientStatus {
  ACTIVE
  INACTIVE
}

/// Immutable, append-only audit trail for every state-changing action across the
/// platform (territory edits, endorsements, policy confirmations, user-admin
/// access changes, AI-drafted-record confirmations, etc.). Never updated or
/// deleted by application code.
///
/// `clientId` is null for actions against shared/global entities (e.g. Territory,
/// user administration); non-null for client-scoped entities. This is the field
/// the RLS policy below filters on.
model AuditLogEntry {
  id           String      @id @default(cuid())
  actorUserId  String
  actorRole    UserRole
  clientId     String?
  entityType   String
  entityId     String
  action       AuditAction
  diff         Json?
  createdAt    DateTime    @default(now())

  @@index([clientId])
  @@index([entityType, entityId])
  @@index([createdAt])
  @@map("audit_log_entries")
}

// ---------------------------------------------------------------------------
// Multi-tenant backbone: Client, BrokerOrganisation, ClientBrokerAssignment.
// Client is the tenant root — AuthContext.clientId is a Client.id. RLS is
// keyed on app.current_client_id / app.current_broker_org_id (see the pattern
// in prisma/migrations/0001_init/migration.sql and 0004_client_broker).
// ---------------------------------------------------------------------------

/// An insured association/organisation (e.g. GRAA). Tenant root: every
/// client-scoped table's clientId points here. Never holds insured-person or
/// financial data directly — those hang off its Policies/Organisations.
model Client {
  id          String                   @id @default(cuid())
  /// Human-readable name (anonymised placeholder only in seed/fixtures).
  name        String
  /// Stable URL-safe slug used in routes and logs (e.g. "graa").
  code        String                   @unique
  status      ClientStatus             @default(ACTIVE)
  createdAt   DateTime                 @default(now())
  updatedAt   DateTime                 @updatedAt
  assignments ClientBrokerAssignment[]

  @@index([status])
  @@map("clients")
}

/// A brokerage servicing one or more Clients (e.g. Lombard's own brokerage or
/// a third-party broker). Shared admin entity — no clientId, Insurer-managed.
/// BROKER users belong to a BrokerOrganisation via Clerk metadata.
model BrokerOrganisation {
  id          String                   @id @default(cuid())
  name        String
  code        String                   @unique
  createdAt   DateTime                 @default(now())
  updatedAt   DateTime                 @updatedAt
  assignments ClientBrokerAssignment[]

  @@map("broker_organisations")
}

/// Effective-dated link between a Client and the BrokerOrganisation servicing
/// it. A broker change at renewal closes the old row (effectiveTo set) and
/// opens a new one, so history is never lost. effectiveTo IS NULL = current.
model ClientBrokerAssignment {
  id                   String             @id @default(cuid())
  clientId             String
  client               Client             @relation(fields: [clientId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  brokerOrganisationId String
  brokerOrganisation   BrokerOrganisation @relation(fields: [brokerOrganisationId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  effectiveFrom        DateTime           @default(now())
  effectiveTo          DateTime?
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt

  @@index([clientId])
  @@index([brokerOrganisationId])
  @@index([effectiveTo])
  @@map("client_broker_assignments")
}

// ---------------------------------------------------------------------------
// Shared / global Territory risk register (no clientId, no RLS).
// ---------------------------------------------------------------------------

/// Country or rated sub-region (e.g. "Nigeria" + "North-East"). Shared source of
/// truth maintained by the Insurer. Empty string for subRegion = whole-country.
model Territory {
  id                       String                  @id @default(cuid())
  country                  String
  /// Empty string when the row rates the whole country (not a sub-region).
  subRegion                String                  @default("")
  graaPresence             Boolean                 @default(false)
  countryHeadcount         Int?
  healthcareInfrastructure Int
  medicalPersonnel         Int
  medicalTransport         Int
  emergencyResponse        Int
  securityConflict         Int
  occupationalHazards      Int
  totalScore               Int
  riskCategory             RiskCategory
  evacuationPaths          String?
  evacCostEstimate         Decimal?                @db.Decimal(12, 2)
  benefitOptions           BenefitOptionsAvailable
  contextNotes             String?
  evacuationFeasible       Boolean                 @default(true)
  /// Optional join key to geoBoundaries ADM1 externalId when mapped.
  adminBoundaryExternalId  String?
  isoCountry               String?
  createdAt                DateTime                @default(now())
  updatedAt                DateTime                @updatedAt
  history                  TerritoryRiskHistory[]

  @@unique([country, subRegion])
  @@index([riskCategory])
  @@index([graaPresence])
  @@index([isoCountry])
  @@map("territories")
}

/// Immutable snapshot of risk scores after each Insurer edit.
/// Parent delete is RESTRICT so history cannot be destroyed under audit.
model TerritoryRiskHistory {
  id                       String       @id @default(cuid())
  territoryId              String
  territory                Territory    @relation(fields: [territoryId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  healthcareInfrastructure Int
  medicalPersonnel         Int
  medicalTransport         Int
  emergencyResponse        Int
  securityConflict         Int
  occupationalHazards      Int
  totalScore               Int
  riskCategory             RiskCategory
  actorUserId              String
  createdAt                DateTime     @default(now())

  @@index([territoryId])
  @@index([createdAt])
  @@map("territory_risk_history")
}

// ---------------------------------------------------------------------------
// Shared / global spatial reference layers (no clientId, no RLS).
// Geometry columns are Unsupported — spatial I/O via $queryRaw/$executeRaw
// only. See docs/prisma-postgis-geometry.md and src/lib/db/spatial.ts.
// ---------------------------------------------------------------------------

/// Provenance row for one import of a spatial dataset (source + last refresh).
model SpatialDatasetRefresh {
  id              String   @id @default(cuid())
  /// Stable source key: geoboundaries | ourairports | healthsites | geonames
  source          String   @unique
  lastRefreshedAt DateTime
  checksum        String?
  rowCount        Int?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  adminBoundaries  AdminBoundary[]
  airports         Airport[]
  healthFacilities HealthFacility[]
  places           Place[]

  @@map("spatial_dataset_refreshes")
}

/// Sub-national admin polygon (geoBoundaries ADM1). isoCountry = ISO alpha-3.
model AdminBoundary {
  id              String                    @id @default(cuid())
  externalId      String
  name            String
  isoCountry      String
  shapeType       String                    @default("ADM1")
  source          String
  sourceUpdatedAt DateTime?
  refreshId       String?
  refresh         SpatialDatasetRefresh?    @relation(fields: [refreshId], references: [id], onDelete: SetNull, onUpdate: Cascade)
  /// Opaque to Prisma — read/write via ST_GeomFromText / ST_AsGeoJSON raw SQL.
  geom            Unsupported("geometry(MultiPolygon,4326)")
  createdAt       DateTime                  @default(now())
  updatedAt       DateTime                  @updatedAt

  @@unique([source, externalId])
  @@index([isoCountry])
  @@index([source])
  @@index([refreshId])
  @@map("admin_boundaries")
}

/// Airport / airstrip point (OurAirports). isoCountry = ISO alpha-2.
model Airport {
  id              String                 @id @default(cuid())
  externalId      String
  name            String
  isoCountry      String
  iataCode        String?
  icaoCode        String?
  type            String?
  source          String
  sourceUpdatedAt DateTime?
  refreshId       String?
  refresh         SpatialDatasetRefresh? @relation(fields: [refreshId], references: [id], onDelete: SetNull, onUpdate: Cascade)
  geom            Unsupported("geometry(Point,4326)")
  createdAt       DateTime               @default(now())
  updatedAt       DateTime               @updatedAt

  @@unique([source, externalId])
  @@index([isoCountry])
  @@index([source])
  @@index([refreshId])
  @@map("airports")
}

/// Hospital / clinic point (healthsites.io). isoCountry = ISO alpha-3 when known.
model HealthFacility {
  id              String                 @id @default(cuid())
  externalId      String
  name            String
  isoCountry      String?
  amenity         String?
  source          String
  sourceUpdatedAt DateTime?
  refreshId       String?
  refresh         SpatialDatasetRefresh? @relation(fields: [refreshId], references: [id], onDelete: SetNull, onUpdate: Cascade)
  geom            Unsupported("geometry(Point,4326)")
  createdAt       DateTime               @default(now())
  updatedAt       DateTime               @updatedAt

  @@unique([source, externalId])
  @@index([isoCountry])
  @@index([source])
  @@index([refreshId])
  @@map("health_facilities")
}

/// Populated place point (GeoNames). isoCountry = ISO alpha-2.
model Place {
  id              String                 @id @default(cuid())
  externalId      String
  name            String
  isoCountry      String
  featureClass    String?
  featureCode     String?
  population      Int?
  source          String
  sourceUpdatedAt DateTime?
  refreshId       String?
  refresh         SpatialDatasetRefresh? @relation(fields: [refreshId], references: [id], onDelete: SetNull, onUpdate: Cascade)
  geom            Unsupported("geometry(Point,4326)")
  createdAt       DateTime               @default(now())
  updatedAt       DateTime               @updatedAt

  @@unique([source, externalId])
  @@index([isoCountry])
  @@index([source])
  @@index([refreshId])
  @@map("places")
}
